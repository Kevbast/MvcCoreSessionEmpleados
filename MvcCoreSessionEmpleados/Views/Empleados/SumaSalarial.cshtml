<h1 style="color:blue">Suma salarial session</h1>

<p>
    <a asp-controller="Empleados" asp-action="SessionSalarios">Volver a salarios empleados</a>
</p>

@if (Context.Session.GetString("SUMASALARIAL") != null)
{
    <h2>Suma salarial:
        <span style="color:blueviolet">@Context.Session.GetString("SUMASALARIAL")</span>
    </h2>
}
else
{
    <h2 style="color:darkred"> NO TIENE SALARIOS ALMACENADOS EN SESSION</h2>
}
