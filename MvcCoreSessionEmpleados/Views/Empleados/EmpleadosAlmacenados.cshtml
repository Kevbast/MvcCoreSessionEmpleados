
@{

    List<Empleado> empleados = Context.Session.GetObject<List<Empleado>>("EMPLEADOS");

}

<h1>Empleados Almacenados</h1>

<p>
    <a asp-controller="Empleados" asp-action="SessionEmpleados">Volver a session empleados</a>
</p>

@if (empleados != null)
{
<table class="table">
    <thead>
        <tr>
            <th>IdEmpleado</th>
            <th>Apellido</th>
            <th>Oficio</th>
            <th>Salario</th>
            <th>IdDepartamento</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in empleados) {
        <tr>
            <td>
                @item.IdEmpleado
            </td>
            <td>
                @item.Apellido
            </td>
            <td>
                @item.Oficio
            </td>
            <td>
                @item.Salario
            </td>
            <td>
                @item.IdDepartamento
            </td>
        </tr>
    }
    </tbody>
</table>

}
else
{
    <h2 style="color:darkred"> NO TIENE EMPLEADOS ALMACENADOS EN SESSION</h2>
}
